# Database
DATABASE_URL="postgresql://username:password@localhost:5432/database_name"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"
AUTH_SECRET="your-secret-key-here"
AUTH_TRUST_HOST="true"

# Wasabi S3-Compatible Storage
WASABI_ENDPOINT="s3.us-west-1.wasabisys.com"
WASABI_REGION="us-west-1"
WASABI_ACCESS_KEY_ID="your-wasabi-access-key"
WASABI_SECRET_ACCESS_KEY="your-wasabi-secret-key"
WASABI_BUCKET="your-bucket-name"

# Bunny.net CDN
BUNNY_CDN_URL="https://your-pull-zone.b-cdn.net"
BUNNY_API_KEY="your-bunny-api-key"
BUNNY_STORAGE_ZONE="your-storage-zone-name"

# Email Configuration (for SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-email@example.com"
SMTP_PASS="your-email-password"
FROM_EMAIL="noreply@example.com"

# OpenAI API (if using AI features)
OPENAI_API_KEY="your-openai-api-key"

# Other API Keys
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
RUNWAYML_API_KEY="your-runwayml-api-key"
PIKA_API_KEY="your-pika-api-key"

# Google Cloud Vertex AI
GOOGLE_CLOUD_PROJECT_ID="your-google-cloud-project-id"
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS="path/to/service-account.json"

# Additional AI Providers
REPLICATE_API_TOKEN="your-replicate-token"
SEEDANCE_API_KEY="your-seedance-key"
WAN_API_KEY="your-wan-key"
HEYGEN_API_KEY="your-heygen-key"
STABILITY_API_KEY="your-stability-key"
ANTHROPIC_API_KEY="your-anthropic-key"

# Stock Media APIs
PEXELS_API_KEY="your-pexels-key"
PIXABAY_API_KEY="your-pixabay-key"
UNSPLASH_API_KEY="your-unsplash-key"
