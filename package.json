{
  "name": "nextn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && cross-env NODE_OPTIONS=\"--max-old-space-size=6144\" NEXT_PRIVATE_BUILD_WORKER=0 NEXT_DISABLE_SWC_WORKER=1 next build",
    "build:docker": "cross-env NODE_OPTIONS=\"--max-old-space-size=6144\" NEXT_PRIVATE_BUILD_WORKER=0 NEXT_DISABLE_SWC_WORKER=1 next build",
    "build:docker:debug-memory": "cross-env NEXT_DISABLE_SWC_WORKER=1 NEXT_PRIVATE_BUILD_WORKER=0 next build --experimental-debug-memory-usage",
    "start": "next start",
    "genkit:dev": "genkit start -- tsx src/ai/dev-index.ts",
    "genkit:watch": "genkit start -- tsx --watch src/ai/dev-index.ts",
    "lint": "next lint",
    "typecheck": "cross-env NODE_OPTIONS=\"--max-old-space-size=6144\" tsc --noEmit",
    "ai:contracts": "tsx tests/ai-provider-contract.ts",
    "workflow:contracts": "tsx tests/workflow-validation-contract.ts",
    "test:integration:auth": "node --import tsx --test tests/integration/auth-hardening.test.ts",
    "test:integration:ai": "node --import tsx --test tests/integration/ai-workflow-contracts.test.ts",
    "test:e2e:ai": "node --import tsx --test tests/integration/ai-workflow-e2e.test.ts",
    "test:integration:login-auth": "node --import tsx --test tests/integration/auth-login-oauth.test.ts",
    "test:integration:routes:contracts": "node --import tsx --test tests/integration/route-auth-contract.test.ts",
    "test:integration:routes:behavior": "node --import tsx --test tests/integration/route-auth-behavior.test.ts",
    "test:integration:routes": "npm run test:integration:routes:contracts && npm run test:integration:routes:behavior",
    "test:integration": "npm run test:integration:auth && npm run test:integration:login-auth && npm run test:integration:ai && npm run test:e2e:ai && npm run test:integration:routes",
    "prisma:validate": "prisma validate",
    "prisma:migrate:check": "prisma migrate status",
    "ai:map": "tsx scripts/generate-ai-provider-map.ts",
    "prisma:migrate:dev": "npx prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "worker": "tsx lib/worker.ts",
    "storage:backfill-media": "tsx scripts/backfill-media-assets-from-storage.ts",
    "storage:repair-media-urls": "tsx scripts/repair-media-asset-urls.ts",
    "deploy:preflight": "node scripts/deploy-preflight.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts",
    "binaryTargets": [
      "native",
      "debian-openssl-3.0.x"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@auth/prisma-adapter": "^2.4.2",
    "@aws-sdk/client-s3": "3.556.0",
    "@aws-sdk/s3-request-presigner": "3.556.0",
    "@bull-board/express": "^5.0.0",
