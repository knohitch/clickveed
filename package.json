    "lucide-react": "^0.475.0",
    "next": "^14.2.33",
    "next-auth": "^5.0.0-beta.29",
    "next-themes": "^0.3.0",
    "nodemailer": "^6.9.14",
    "openai": "^4.52.7",
    "pexels": "^1.4.0",
    "pixabay-api": "^1.0.4",
    "prisma": "^5.15.0",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^16.5.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "unsplash-js": "^7.0.19",
    "wav": "^1.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.15",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/wav": "^1.0.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
